{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/brand/**",
              "components/buttons/**",
              "components/core/**",
              "components/forms/**",
              "components/marketing/**",
              "site/**",
              "ui_kits/booking/**",
              "ui_kits/website/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Archivo|Hanken Grotesk|Spline Sans Mono))/i]",
        "message": "Font not provided by the design system. Available: Archivo, Hanken Grotesk, Spline Sans Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|size|icon|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: tone, size, icon."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:blue|navy|accent|green|amber|gray|solid)$/]",
        "message": "<Badge> tone must be one of 'blue' | 'navy' | 'accent' | 'green' | 'amber' | 'gray' | 'solid'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<Badge> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|block|iconLeft|iconRight|as|href|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, block, iconLeft, iconRight, as, href."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|accent|navy|outline|ghost|on-dark)$/]",
        "message": "<Button> variant must be one of 'primary' | 'accent' | 'navy' | 'outline' | 'ghost' | 'on-dark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:hover|pad|as|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: hover, pad, as."
      },
      {
        "selector": "JSXOpeningElement[name.name='GuaranteeCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|title|tone|key|ref|className|style|children)$/]",
        "message": "<GuaranteeCard> doesn't accept that prop. Declared props: icon, title, tone."
      },
      {
        "selector": "JSXOpeningElement[name.name='GuaranteeCard'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:blue|navy)$/]",
        "message": "<GuaranteeCard> tone must be one of 'blue' | 'navy'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|required|icon|hint|error|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, required, icon, hint, error."
      },
      {
        "selector": "JSXOpeningElement[name.name='Logo'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|showWordmark|size|href|key|ref|className|style|children)$/]",
        "message": "<Logo> doesn't accept that prop. Declared props: tone, showWordmark, size, href."
      },
      {
        "selector": "JSXOpeningElement[name.name='Logo'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:light|dark)$/]",
        "message": "<Logo> tone must be one of 'light' | 'dark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='RatingBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|count|label|size|key|ref|className|style|children)$/]",
        "message": "<RatingBadge> doesn't accept that prop. Declared props: value, count, label, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='RatingBadge'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:md|lg)$/]",
        "message": "<RatingBadge> size must be one of 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ReviewCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:rating|quote|author|location|source|key|ref|className|style|children)$/]",
        "message": "<ReviewCard> doesn't accept that prop. Declared props: rating, quote, author, location, source."
      },
      {
        "selector": "JSXOpeningElement[name.name='Select'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|required|hint|error|key|ref|className|style|children)$/]",
        "message": "<Select> doesn't accept that prop. Declared props: label, required, hint, error."
      },
      {
        "selector": "JSXOpeningElement[name.name='ServiceCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|title|index|href|linkLabel|key|ref|className|style|children)$/]",
        "message": "<ServiceCard> doesn't accept that prop. Declared props: icon, title, index, href, linkLabel."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],

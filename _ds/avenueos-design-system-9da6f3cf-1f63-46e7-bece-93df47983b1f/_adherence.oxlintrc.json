{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/data/**",
              "components/navigation/**",
              "ui_kits/avenueos/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Inter|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Inter, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|disabled|iconLeft|iconRight|style|onClick|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, disabled, iconLeft, iconRight, style, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|subtle|danger)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'subtle' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<Button> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|interactive|padded|style|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: children, interactive, padded, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='DataTableColumn'] > JSXAttribute > JSXIdentifier[name!=/^(?:key|label|align|mono|strong|width|sortable|render|key|ref|className|style|children)$/]",
        "message": "<DataTableColumn> doesn't accept that prop. Declared props: key, label, align, mono, strong, width, sortable, render."
      },
      {
        "selector": "JSXOpeningElement[name.name='DataTableColumn'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:left|right|center)$/]",
        "message": "<DataTableColumn> align must be one of 'left' | 'right' | 'center'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|onChange|placeholder|iconLeft|mono|size|disabled|style|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: value, onChange, placeholder, iconLeft, mono, size, disabled, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<Input> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='KPICard'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|unit|trend|spark|accent|style|key|ref|className|style|children)$/]",
        "message": "<KPICard> doesn't accept that prop. Declared props: label, value, unit, trend, spark, accent, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProgressBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|color|height|showLabel|style|key|ref|className|style|children)$/]",
        "message": "<ProgressBar> doesn't accept that prop. Declared props: value, color, height, showLabel, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Sparkline'] > JSXAttribute > JSXIdentifier[name!=/^(?:data|width|height|trend|strokeWidth|fill|key|ref|className|style|children)$/]",
        "message": "<Sparkline> doesn't accept that prop. Declared props: data, width, height, trend, strokeWidth, fill."
      },
      {
        "selector": "JSXOpeningElement[name.name='Sparkline'] > JSXAttribute[name.name='trend'] > Literal[value!=/^(?:up|down|flat)$/]",
        "message": "<Sparkline> trend must be one of 'up' | 'down' | 'flat'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:status|children|style|key|ref|className|style|children)$/]",
        "message": "<StatusBadge> doesn't accept that prop. Declared props: status, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusBadge'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:success|live|warning|error|info|neutral)$/]",
        "message": "<StatusBadge> status must be one of 'success' | 'live' | 'warning' | 'error' | 'info' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TabItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:id|label|key|ref|className|style|children)$/]",
        "message": "<TabItem> doesn't accept that prop. Declared props: id, label."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {

# AvenueOS Agent Environment Variables
# Copy this to .env and fill in real values.
# NEVER commit the .env file to git.

# ─── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── GitHub ───────────────────────────────────────────────────────────────────
# GitHub owner and repo for the AvenueOS site repository
GITHUB_OWNER=jddjunior
GITHUB_REPO=avenueos

# ─── Agent IDs (populated by running: bun agents/setup.ts) ───────────────────
# These are created ONCE and then reused. Run setup.ts to generate them.
AVENUEOS_ORCHESTRATOR_AGENT_ID=
AVENUEOS_SEO_AGENT_ID=
AVENUEOS_ADS_AGENT_ID=
AVENUEOS_CRO_AGENT_ID=
AVENUEOS_WEB_AGENT_ID=
AVENUEOS_CALL_AGENT_ID=
AVENUEOS_REPORT_AGENT_ID=
AVENUEOS_VALIDATOR_AGENT_ID=

# ─── Demo Tenant (for testing run-task.ts) ────────────────────────────────────
DEMO_BUILDER_SPACE_ID=your-builder-io-space-id
DEMO_BUILDER_API_KEY=your-builder-io-private-key
